{
  "name": "mintlifier",
  "version": "2.1.1",
  "description": "Interactive CLI tool for building current Mintlify docs.json configurations with versioning helpers",
  "type": "module",
  "main": "index.js",
  "bin": {
    "mintlifier": "./bin/mintlifier.js"
  },
  "scripts": {
    "start": "node index.js",
    "test": "node --test test/*.test.js",
    "build-docs": "node scripts/build-docs.js"
  },
  "keywords": [
    "mintlify",
    "documentation",
    "docs",
    "cli",
    "generator",
    "configuration",
    "versioning",
    "docs.json",
    "mdx",
    "openapi",
    "swagger",
    "gitbook",
    "notion",
    "docusaurus"
  ],
  "author": "Cordt <cordtus@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cordtus/mintlifier.git"
  },
  "bugs": {
    "url": "https://github.com/Cordtus/mintlifier/issues"
  },
  "homepage": "https://github.com/Cordtus/mintlifier#readme",
  "dependencies": {
    "@inquirer/prompts": "^7.8.3",
    "chalk": "^5.6.0",
    "fs-extra": "^11.3.1",
    "glob": "^11.0.3",
    "ora": "^8.2.0"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "preferGlobal": false,
  "files": [
    "bin/",
    "index.js",
    "automate-config.js",
    "lib/",
    "scripts/",
    "test/",
    "workflow-templates/",
    "schema.json",
    "docs-json-schema.json",
    "docs-json-schema.d.ts",
    "LICENSE",
    "README.md"
  ]
}
